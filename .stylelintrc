{
  "customSyntax": "postcss-scss",
  "plugins": ["stylelint-scss"],
  "extends": ["stylelint-config-recommended-scss"],
  "rules": {
    "scss/at-rule-no-unknown": true,
    "selector-class-pattern": "^[a-z0-9]+(-[a-z0-9]+)*(__[a-z0-9]+)?(--[a-z0-9]+)?$",
    "block-no-empty": true,
    "color-no-invalid-hex": true
  }
}